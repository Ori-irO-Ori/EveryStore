# ============================================================
#  EveryStore — Environment Configuration
#  1. Copy this file:  cp .env.example .env
#  2. Fill in your values below
#  3. NEVER commit .env to git
# ============================================================

# ----- Django Core -----
SECRET_KEY=change-me-to-a-long-random-string-at-least-50-chars
DEBUG=False
# Comma-separated. Add your EC2 public IP and/or domain.
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,your-ec2-ip

# ----- Database (AWS RDS PostgreSQL) -----
# Local dev: leave DB_HOST=everystore-db to use the bundled postgres container.
# Production: set DB_HOST to your RDS endpoint, e.g. mydb.abc123.us-east-1.rds.amazonaws.com
DB_HOST=everystore-db
DB_PORT=5432
DB_NAME=everystore
DB_USER=everystore
DB_PASS=your-strong-database-password
# 'require' for RDS (SSL enforced), 'disable' for local dev container
DB_SSLMODE=disable

# ----- AWS S3 (Product Image Storage) -----
# All images uploaded via admin panel are stored in S3 automatically.
S3_BUCKET=your-s3-bucket-name
S3_REGION=us-east-1
S3_ACCESS_KEY=AKIAxxxxxxxxxxxxxxxx
S3_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----- PayPal Payment -----
# PAYMENT_MODE: 'sandbox' for testing, 'live' for real payments.
# Get your credentials at: https://developer.paypal.com/dashboard/applications
# Sandbox: create a sandbox app → copy Client ID and Secret
# Live: create a live app → copy Client ID and Secret, change PAYMENT_MODE=live
PAYMENT_MODE=sandbox
PAYPAL_CLIENT_ID=AXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYPAL_CLIENT_SECRET=EXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----- SSL / HTTPS -----
# Option A — Let's Encrypt (recommended): fill DOMAIN + CERTBOT_EMAIL.
#   Cert is obtained and renewed automatically. Requires port 80/443 open.
DOMAIN=yourdomain.com
CERTBOT_EMAIL=you@example.com

# Option B — Custom certificate: provide absolute paths on the host machine.
#   If set, takes priority over Let's Encrypt.
SSL_CERT_PATH=
SSL_KEY_PATH=

# Option C — Nothing set above: a self-signed cert is generated automatically.
#   HTTPS works immediately but the browser shows a security warning.

# ----- Store Settings -----
# ----- Email (Order Confirmation) -----
# Supports any SMTP provider. Gmail example shown below.
# Gmail: enable 2-Step Verification, then generate an App Password at
#   https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_HOST_USER=you@gmail.com
EMAIL_HOST_PASSWORD=xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Your Store <you@gmail.com>

STORE_NAME=EveryStore
STORE_CURRENCY=USD

# ----- Seller Contact (displayed prominently on storefront) -----
# SELLER_CONTACT_TYPE: email | discord | whatsapp | telegram | wechat
SELLER_CONTACT_TYPE=email
SELLER_CONTACT_VALUE=hello@yourstore.com

# ----- Theme -----
# Hex color for buttons and accents
THEME_PRIMARY_COLOR=#6366f1
# Full URL to your logo (leave empty to use store name as text)
THEME_LOGO_URL=
# Full URL to homepage hero/banner image (leave empty for gradient fallback)
THEME_HERO_IMAGE_URL=
